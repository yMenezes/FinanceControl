# ──────────────────────────────────────────────────────────────
# FinTrack — Environment Variables
#
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your values from the Supabase dashboard
# 3. NEVER commit .env.local to version control
# ──────────────────────────────────────────────────────────────

# Supabase project URL
# Found at: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — safe to expose in the browser
# Found at: Supabase Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — NEVER expose this in the browser
# Used only in server-side code (API Routes)
# Found at: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
